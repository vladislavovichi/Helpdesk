{%- macro bar_chart(rows) -%}
  {% if rows %}
    <div class="bar-chart">
      {% for row in rows %}
        <div class="bar-row">
          <div class="bar-head">
            <div class="bar-label">{{ row.label }}</div>
            <div class="bar-value">{{ row.value }}</div>
          </div>
          <div class="bar-track">
            <div class="bar-fill" style="width: {{ row.width }}%; background: {{ row.color }};"></div>
          </div>
        </div>
      {% endfor %}
    </div>
  {% else %}
    <div class="empty-state">Данных пока недостаточно.</div>
  {% endif %}
{%- endmacro -%}
<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Analytics report · {{ title }}</title>
  <style>
{{ css | safe }}
  </style>
</head>
<body>
  <div class="page">
    <section class="cover">
      <div class="cover-grid">
        <div>
          <p class="eyebrow">Analytics report</p>
          <h1>{{ title }}</h1>
          <p class="hero-copy">{{ hero_copy }}</p>
          <div class="chip-row">
            <span class="chip">HTML отчёт с графиками</span>
            <span class="chip">Период: {{ window_label }}</span>
            <span class="chip">Подготовлен: {{ generated_at }}</span>
            <span class="chip">Static executive report</span>
          </div>
        </div>
        <aside class="cover-aside">
          {% for metric in cover_metrics %}
            <article class="cover-metric">
              <div class="cover-label">{{ metric.label }}</div>
              <div class="cover-value">{{ metric.value }}</div>
            </article>
          {% endfor %}
        </aside>
      </div>
    </section>

    <section class="kpi-board" aria-label="KPI board">
      {% for card in stat_cards %}
        <article class="stat-card">
          <div class="stat-label">{{ card.label }}</div>
          <div class="stat-value">{{ card.value }}</div>
          <div class="stat-note">{{ card.note }}</div>
        </article>
      {% endfor %}
    </section>

    <section class="report-section">
      <div class="section-head">
        <div>
          <p class="eyebrow">Insights</p>
          <h2>{{ insight_title }}</h2>
        </div>
        <span class="chip">{{ window_label }}</span>
      </div>
      <div class="metrics">
        {% for metric in section_metrics %}
          <div class="metric-row">
            <div class="metric-label">{{ metric.label }}</div>
            <div class="metric-value">{{ metric.value }}</div>
          </div>
        {% endfor %}
      </div>
    </section>

    <section class="charts-grid" aria-label="Charts">
      {% for chart in charts %}
        <article class="chart-card">
          <h2>{{ chart.title }}</h2>
          <div class="chart-note">{{ chart.note }}</div>
          {% if chart.kind == "status_mix" %}
            <div class="chart-body">
              <div class="legend-value">Всего {{ chart.total }}</div>
              <div class="segment-track" role="img" aria-label="Статусный портрет">
                {% for segment in chart.segments %}
                  <div class="segment-fill" style="width: {{ segment.width }}%; background: {{ segment.color }};"></div>
                {% endfor %}
              </div>
              <div class="segment-legend">
                {% for row in chart.legend %}
                  <div class="legend-row">
                    <div class="legend-label">{{ row.label }}</div>
                    <div class="legend-value">{{ row.value }}</div>
                  </div>
                {% endfor %}
              </div>
            </div>
          {% else %}
            {{ bar_chart(chart.rows) }}
          {% endif %}
        </article>
      {% endfor %}
    </section>

    <footer class="report-footer">
      <span>Generated by Reliora</span>
      <span>{{ generated_at }}</span>
      <span>{{ title }} · {{ window_label }}</span>
      <span>Static export file</span>
    </footer>
  </div>
</body>
</html>
